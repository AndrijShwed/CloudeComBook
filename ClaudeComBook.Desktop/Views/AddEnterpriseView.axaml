<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ClaudeComBook.Desktop.Views.AddEnterpriseView"
        Title="Додати підприємство"
        WindowState="Maximized"
        Background="#8B0000">

	<Grid RowDefinitions="Auto,*,Auto" Margin="20">

		<!-- Хлібні крихти -->
		<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
			<TextBlock Text="Головна/" Foreground="White" FontSize="13"
					   Cursor="Hand" Tapped="OnHomeClick"/>
			<TextBlock Text=" Підприємства/" Foreground="White" FontSize="13"
					   Cursor="Hand" Tapped="OnEnterprisesClick"/>
			<TextBlock Text=" Додати" Foreground="White" FontSize="13" FontWeight="Bold"/>
		</StackPanel>

		<!-- Поля -->
		<Grid Grid.Row="1" ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">

			<!-- Колонка 1 -->
			<StackPanel Grid.Column="0" Grid.Row="0" Margin="10,10">
				<TextBlock Foreground="White" FontSize="16" Margin="0,0,0,5">
					<Run Text="Населений пункт"/>
					<Run Text=" *" Foreground="Red"/>
				</TextBlock>
				<ComboBox Name="VillageBox" HorizontalAlignment="Stretch"/>
			</StackPanel>

			<StackPanel Grid.Column="0" Grid.Row="1" Margin="10,10">
				<TextBlock Foreground="White" FontSize="16" Margin="0,0,0,5">
					<Run Text="Вулиця"/>
					<Run Text=" *" Foreground="Red"/>
				</TextBlock>
				<ComboBox Name="StreetBox" HorizontalAlignment="Stretch"/>
			</StackPanel>

			<StackPanel Grid.Column="0" Grid.Row="2" Margin="10,10">
				<TextBlock Text="Номер будинку" Foreground="White" FontSize="16" Margin="0,0,0,5"/>
				<TextBox Name="HouseNumberBox" Background="White" Foreground="Black"/>
			</StackPanel>

			<!-- Колонка 2 -->
			<StackPanel Grid.Column="1" Grid.Row="0" Margin="10,10">
				<TextBlock Foreground="White" FontSize="16" Margin="0,0,0,5">
					<Run Text="Назва підприємства"/>
					<Run Text=" *" Foreground="Red"/>
				</TextBlock>
				<TextBox Name="NameBox" Background="White" Foreground="Black"/>
			</StackPanel>

			<StackPanel Grid.Column="1" Grid.Row="1" Margin="10,10">
				<TextBlock Text="Кількість працівників" Foreground="White" FontSize="16" Margin="0,0,0,5"/>
				<TextBox Name="EmployeesBox" Background="White" Foreground="Black"/>
			</StackPanel>

			<StackPanel Grid.Column="1" Grid.Row="2" Margin="10,10">
				<TextBlock Foreground="White" FontSize="16" Margin="0,0,0,5">
					<Run Text="ПІБ власника"/>
					<Run Text=" *" Foreground="Red"/>
				</TextBlock>
				<TextBox Name="OwnerBox" Background="White" Foreground="Black"/>
			</StackPanel>

		</Grid>

		<!-- Кнопка збереження -->
		<Button Grid.Row="2" Content="Зберегти"
				Background="#E8603C" Foreground="White"
				FontSize="16" FontWeight="Bold"
				Padding="30,10" Margin="10,20,0,0"
				CornerRadius="5"
				Click="OnSaveClick"/>

	</Grid>
</Window>
