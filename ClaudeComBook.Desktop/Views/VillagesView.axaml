<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:local="using:ClaudeComBook.Desktop.Models"
        x:Class="ClaudeComBook.Desktop.Views.VillagesView"
        Title="Населені пункти"
        Width="600" Height="500"
        Background="White">

	<Grid RowDefinitions="Auto,*">

		<!-- Заголовок -->
		<TextBlock Grid.Row="0" Text="Населені пункти"
				   FontSize="20" FontWeight="Bold"
				   Margin="20,15" HorizontalAlignment="Center"/>

		<!-- Список -->
		<ListBox Grid.Row="1" Name="VillagesList"
				 Margin="20"
				 FontSize="16">
			<ListBox.ItemTemplate>
				<DataTemplate x:DataType="local:Village">
					<TextBlock Text="{Binding Name}" Padding="5"/>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>

	</Grid>
</Window>
