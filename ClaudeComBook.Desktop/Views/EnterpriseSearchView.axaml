<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:ClaudeComBook.Desktop.Models"
        x:Class="ClaudeComBook.Desktop.Views.EnterpriseSearchView"
        Title="Підприємства пошук"
        WindowState="Maximized"
        Background="#8B0000">
	<Window.Styles>
		<Style Selector="TextBox /template/ ScrollViewer">
			<Setter Property="Foreground" Value="Black"/>
		</Style>
	</Window.Styles>

	<Grid RowDefinitions="Auto,Auto,Auto,*" Margin="10">

		<!-- Хлібні крихти -->
		<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,8">
			<TextBlock Text="Головна/" Foreground="White" FontSize="13"
					   Cursor="Hand" Tapped="OnHomeClick"/>
			<TextBlock Text=" Підприємства пошук" Foreground="White"
					   FontSize="13" FontWeight="Bold"/>
		</StackPanel>

		<!-- Панель пошуку -->
		<Border Grid.Row="1" Margin="0,5" BorderBrush="Gray"
				BorderThickness="1" CornerRadius="5" Padding="10">
			<Grid RowDefinitions="Auto,Auto">

				<!-- Рядок 1 -->
				<Grid Grid.Row="0" ColumnDefinitions="Auto,*,*" Margin="0,5">
					<TextBlock Grid.Column="0" Text="Введіть дані :"
							   Foreground="White" FontWeight="Bold"
							   FontSize="14" VerticalAlignment="Center" Margin="0,0,15,0"/>
					<TextBox Grid.Column="1" Name="NameBox"
							 PlaceholderText="Назва п-ства" Margin="5,0"/>
					<TextBox Grid.Column="2" Name="OwnerBox"
							 PlaceholderText="ПІБ власника" Margin="5,0"/>
				</Grid>

				<!-- Рядок 2 -->
				<Grid Grid.Row="1" ColumnDefinitions="*,*,*,Auto,Auto" Margin="0,5">
					<ComboBox Grid.Column="0" Name="VillageBox"
							  PlaceholderText="Населений пункт" Margin="5,0"/>
					<ComboBox Grid.Column="1" Name="StreetBox"
							  PlaceholderText="Вулиця" Margin="5,0"/>
					<TextBox Grid.Column="2" Name="HouseNumberBox"
							 PlaceholderText="Номер будинку" Margin="5,0"/>
					<Button Grid.Column="3" Content="Пошук"
							Background="#FFD700" Foreground="Black"
							FontWeight="Bold" Padding="15,8" Margin="5,0"
							CornerRadius="10" Click="OnSearchClick"/>
					<Button Grid.Column="4" Content="Очистити поля"
							Background="#8B7536" Foreground="White"
							FontWeight="Bold" Padding="15,8" Margin="5,0"
							CornerRadius="10" Click="OnClearClick"/>
				</Grid>
			</Grid>
		</Border>

		<!-- Лічильник і кнопка очистити таблицю -->
		<Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,Auto,*,Auto" Margin="0,5">
			<TextBlock Grid.Column="0" Text="Результат пошуку :"
					   Foreground="White" VerticalAlignment="Center" Margin="5,0"/>
			<TextBlock Grid.Column="1" Name="ResultCount" Text="0"
					   Background="White" Foreground="Black"
					   Padding="10,3" VerticalAlignment="Center"
					   MinWidth="60" TextAlignment="Center" Margin="5,0"/>
			<TextBlock Grid.Column="2" Text=" записів"
					   Foreground="White" VerticalAlignment="Center"/>
			<Button Grid.Column="4" Content="Очистити таблицю"
					Background="#008080" Foreground="White"
					FontWeight="Bold" Padding="15,8"
					Click="OnClearTableClick"/>
		</Grid>

		<!-- Таблиця -->
		<DataGrid Grid.Row="3" Name="EnterprisesGrid"
				  x:DataType="local:Enterprise"
				  DoubleTapped="OnRowDoubleTapped"
				  Margin="0,5"
				  Background="#FFA500"
				  Foreground="Black"
				  IsReadOnly="True"
				  AutoGenerateColumns="False"
				  GridLinesVisibility="All"
				  HeadersVisibility="Column">
			<DataGrid.Columns>
				<DataGridTextColumn Header="Номер" Binding="{Binding Id}" Width="80"/>
				<DataGridTextColumn Header="ПІБ власника" Binding="{Binding Owner}" Width="300"/>
				<DataGridTextColumn Header="Назва п-ства" Binding="{Binding Name}" Width="300"/>
				<DataGridTextColumn Header="Нас. пункт" Binding="{Binding VillageName}" Width="150"/>
				<DataGridTextColumn Header="Вулиця" Binding="{Binding StreetName}" Width="200"/>
				<DataGridTextColumn Header="Номер буд." Binding="{Binding HouseNumber}" Width="100"/>
				<DataGridTextColumn Header="К-сть працівників" Binding="{Binding EmployeesNumber}" Width="130"/>
				<DataGridTemplateColumn Header="Видалити" Width="100">
					<DataGridTemplateColumn.CellTemplate>
						<DataTemplate x:DataType="local:Enterprise">
							<Button Content="Видалити"
									Background="#8B0000"
									Foreground="White"
									FontWeight="Bold"
									Padding="5,3"
									Click="OnDeleteClick"/>
						</DataTemplate>
					</DataGridTemplateColumn.CellTemplate>
				</DataGridTemplateColumn>
			</DataGrid.Columns>
		</DataGrid>

	</Grid>
</Window>
