<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:local="using:ClaudeComBook.Desktop.Views"
        x:Class="ClaudeComBook.Desktop.Views.HouseRoomsView"
        Title="По кількості кімнат"
        WindowState="Maximized"
        Background="#8B0000">

	<Grid RowDefinitions="Auto,Auto,*" Margin="10">

		<!-- Хлібні крихти -->
		<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,8">
			<TextBlock Text="Головна" Foreground="White" FontSize="13"
					   Cursor="Hand" Tapped="OnHomeClick"/>
			<TextBlock Text=" / " Foreground="White" FontSize="13"/>
			<TextBlock Text="Домогосподарства" Foreground="White" FontSize="13"
					   Cursor="Hand" Tapped="OnHouseholdsClick"/>
			<TextBlock Text=" / " Foreground="White" FontSize="13"/>
			<TextBlock Text="По кількості кімнат" Foreground="White" FontSize="13" FontWeight="Bold"/>
		</StackPanel>

		<!-- Кнопка -->
		<Button Grid.Row="1" Content="Оновити дані"
				Background="#E8603C" Foreground="White"
				FontFamily="Comic Sans MS" FontSize="16"
				FontStyle="Italic" FontWeight="Bold"
				Padding="25,10" Margin="0,5,0,10"
				CornerRadius="15"
				Click="OnRefreshClick"/>

		<!-- Таблиця -->
		<DataGrid Grid.Row="2" Name="RoomsGrid"
				  x:DataType="local:RoomsRow"
				  Margin="0,5"
				  Background="#ADD8E6"
				  Foreground="Black"
				  IsReadOnly="True"
				  AutoGenerateColumns="False"
				  GridLinesVisibility="All"
				  HeadersVisibility="Column">
			<DataGrid.Columns>
				<DataGridTextColumn Header="Населений пункт" Binding="{Binding Village}" Width="150"/>
				<DataGridTextColumn Header="Рік" Binding="{Binding Year}" Width="80"/>
				<DataGridTextColumn Header="Одно кімн." Binding="{Binding OneRoom}" Width="100"/>
				<DataGridTextColumn Header="Дво кімн." Binding="{Binding TwoRooms}" Width="100"/>
				<DataGridTextColumn Header="Три кімн." Binding="{Binding ThreeRooms}" Width="100"/>
				<DataGridTextColumn Header="Чотири кімн." Binding="{Binding FourRooms}" Width="110"/>
				<DataGridTextColumn Header="П'ять кімн." Binding="{Binding FiveRooms}" Width="100"/>
				<DataGridTextColumn Header="Шість кімн." Binding="{Binding SixRooms}" Width="100"/>
				<DataGridTextColumn Header="Більше шести кімн." Binding="{Binding MoreThanSix}" Width="150"/>
				<DataGridTextColumn Header="Загальна" Binding="{Binding Total}" Width="100"/>
			</DataGrid.Columns>
		</DataGrid>

	</Grid>
</Window>
