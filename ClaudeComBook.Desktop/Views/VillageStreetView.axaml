<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:ClaudeComBook.Desktop.Models"
        x:Class="ClaudeComBook.Desktop.Views.VillageStreetsView"
		xmlns:dgx="using:Avalonia.Controls"
        Title="Населені пункти"
        WindowState="Maximized"
        Background="White">

	<Grid RowDefinitions="Auto,Auto,*">

		<!-- Хлібні крихти -->
		<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,8">
			<TextBlock Text="Головна" FontSize="13"/>
			<TextBlock Text=" / " FontSize="13"/>
			<TextBlock Text="Населені пункти" FontSize="13" FontWeight="Bold"/>
		</StackPanel>

		<!-- Панель введення -->
		<Grid Grid.Row="1" ColumnDefinitions="*,*,Auto" Margin="10,5">
			<TextBox Grid.Column="0" Name="VillageInputBox"
					 PlaceholderText="Введіть назву населеного пункту"
					 PlaceholderForeground="Black"
					 Margin="5,0" FontSize="14"
					 Background="#ADD8E6"
					 BorderBrush="Gray"
					 BorderThickness="1"/>
			<TextBox Grid.Column="1" Name="StreetInputBox"
					 PlaceholderText="Введіть назву вулиці"
					 PlaceholderForeground="Black"
					 Margin="5,0" FontSize="14"
					 Background="#ADD8E6"
					 BorderBrush="Gray"
					 BorderThickness="1"/>
			<Button Grid.Column="2" Content="Додати в таблицю"
					Background="#8B0000" Foreground="White"
					FontFamily="Comic Sans MS" FontSize="14"
					FontWeight="Bold" Padding="15,8" Margin="5,0"
					Click="OnAddClick"/>
		</Grid>

		<!-- Таблиця -->
		<DataGrid Grid.Row="2" Name="VillageStreetsGrid"
				  x:DataType="local:VillageStreet"
				  Margin="10,5"
				  Background="White"
				  Foreground="Black"
				  IsReadOnly="True"
				  AutoGenerateColumns="False"
				  GridLinesVisibility="All"
				  BorderThickness="1"
				  BorderBrush="Gray"
				  HeadersVisibility="Column">
			<DataGrid.Columns>
				<DataGridTextColumn Header="Номер" Binding="{Binding Id}" Width="80"/>
				<DataGridTextColumn Header="Населений пункт" Binding="{Binding VillageName}" Width="200"/>
				<DataGridTextColumn Header="Вулиця" Binding="{Binding StreetName}" Width="200"/>
				<DataGridTextColumn Header="Стара назва вулиці" Binding="{Binding OldStreetName}" Width="200"/>
				<DataGridTextColumn Header="Дата зміни назви"
                    Binding="{Binding RenameDateFormatted}"
                    Width="150"/>
				<DataGridTemplateColumn Header="Видалити" Width="100">
					<DataGridTemplateColumn.CellTemplate>
						<DataTemplate x:DataType="local:VillageStreet">
							<Button Content="Видалити"
									Background="#8B0000"
									Foreground="White"
									FontWeight="Bold"
									Padding="5,3"
									Click="OnDeleteClick"/>
						</DataTemplate>
					</DataGridTemplateColumn.CellTemplate>
				</DataGridTemplateColumn>
				<DataGridTemplateColumn Header="Документ про перейменування" Width="180">
					<DataGridTemplateColumn.CellTemplate>
						<DataTemplate x:DataType="local:VillageStreet">
							<Button Content="Відкрити"
									Background="#00BCD4"
									Foreground="White"
									FontWeight="Bold"
									Padding="5,3"
									IsVisible="{Binding HasFile}"
									Click="OnOpenFileClick"/>
						</DataTemplate>
					</DataGridTemplateColumn.CellTemplate>
				</DataGridTemplateColumn>
				<DataGridTemplateColumn Header="Заміна документа" Width="160">
					<DataGridTemplateColumn.CellTemplate>
						<DataTemplate x:DataType="local:VillageStreet">
							<Button Content="Замінити документ"
									Background="#FF9800"
									Foreground="White"
									FontWeight="Bold"
									Padding="5,3"
									Click="OnReplaceFileClick"/>
						</DataTemplate>
					</DataGridTemplateColumn.CellTemplate>
				</DataGridTemplateColumn>
			</DataGrid.Columns>
		</DataGrid>

	</Grid>
</Window>