<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ClaudeComBook.Desktop.Views.LandView"
        Title="Земля"
        Background="#8B0000">

	<Grid RowDefinitions="Auto,*">

		<!-- Хлібні крихти -->
		<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,8">
			<TextBlock Text="Головна/" Foreground="White" FontSize="13"
					   Cursor="Hand" Tapped="OnHomeClick"/>
			<TextBlock Text=" Земля" Foreground="White" FontSize="13" FontWeight="Bold"/>
		</StackPanel>
		<TextBlock Name="UserLabel" HorizontalAlignment="Right"
               VerticalAlignment="Center" Foreground="White"
               FontSize="13" Margin="0,0,15,0"/>

		<!-- Кнопки меню -->
		<UniformGrid Grid.Row="1" Columns="2" Margin="80">

			<!-- Додати земельну ділянку -->
			<Button Margin="30" Background="White" CornerRadius="15"
					HorizontalContentAlignment="Center"
					Click="OnAddClick">
				<StackPanel HorizontalAlignment="Center" Margin="10">
					<Image Width="200" Height="180" Source="/Assets/landplus.png"/>
					<TextBlock Text="Додати земельну ділянку" FontFamily="Comic Sans MS"
							   Foreground="Black" FontSize="18" FontStyle="Italic"
							   HorizontalAlignment="Center" Margin="0,8,0,0"/>
				</StackPanel>
			</Button>

			<!-- Знайти земельну ділянку -->
			<Button Margin="30" Background="White" CornerRadius="15"
					HorizontalContentAlignment="Center"
					Click="OnSearchClick">
				<StackPanel HorizontalAlignment="Center" Margin="10">
					<Image Width="200" Height="180" Source="/Assets/search_land.png"/>
					<TextBlock Text="Знайти земельну ділянку" FontFamily="Comic Sans MS"
							   Foreground="Black" FontSize="18" FontStyle="Italic"
							   HorizontalAlignment="Center" Margin="0,8,0,0"/>
				</StackPanel>
			</Button>

		</UniformGrid>
	</Grid>
</Window>
