<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ClaudeComBook.Desktop.Views.HouseAreaView"
        Title="Площі будинків"
        WindowState="Maximized"
        Background="#8B0000">

	<Grid RowDefinitions="Auto,Auto,*" Margin="10">

		<!-- Хлібні крихти -->
		<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,8">
			<TextBlock Text="Головна" Foreground="White" FontSize="13"
					   Cursor="Hand" Tapped="OnHomeClick"/>
			<TextBlock Text=" / " Foreground="White" FontSize="13"/>
			<TextBlock Text="Домогосподарства" Foreground="White" FontSize="13"
					   Cursor="Hand" Tapped="OnHouseholdsClick"/>
			<TextBlock Text=" / " Foreground="White" FontSize="13"/>
			<TextBlock Text="Площі будинків" Foreground="White" FontSize="13" FontWeight="Bold"/>
		</StackPanel>

		<!-- Кнопка -->
		<Button Grid.Row="1" Content="Оновити дані"
				Background="#E8603C" Foreground="White"
				FontFamily="Comic Sans MS" FontSize="16"
				FontStyle="Italic" FontWeight="Bold"
				Padding="25,10" Margin="0,5,0,10"
				CornerRadius="15"
				Click="OnRefreshClick"/>

		<!-- Таблиця -->
		<DataGrid Grid.Row="2" Name="AreaGrid"
				  Margin="0,5"
				  Background="#FFA500"
				  Foreground="Black"
				  IsReadOnly="True"
				  AutoGenerateColumns="False"
				  GridLinesVisibility="All"
				  HeadersVisibility="Column">
		</DataGrid>

	</Grid>
</Window>
