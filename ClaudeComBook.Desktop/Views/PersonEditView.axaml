<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ClaudeComBook.Desktop.Views.PersonEditView"
        Title="Редагувати"
        Width="900" Height="650"
        WindowStartupLocation="CenterScreen"
        Background="#8B0000">
	<Window.Styles>
		<Style Selector="TextBox /template/ ScrollViewer">
			<Setter Property="Foreground" Value="Black"/>
		</Style>
	</Window.Styles>
	

	<Grid RowDefinitions="Auto,*,Auto" Margin="10">

		<!-- Хлібні крихти -->
		<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,8">
			<TextBlock Text="Вікно пошуку" Foreground="White" FontSize="13" Cursor="Hand"
					    Tapped="OnSearchWindowClick"/>
			<TextBlock Text=" / " Foreground="White" FontSize="13"/>
			<TextBlock Text="Редагування" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,0,0,20"/>
		</StackPanel>
		<TextBlock Name="UserLabel" HorizontalAlignment="Right"
               VerticalAlignment="Center" Foreground="White"
               FontSize="13" Margin="0,0,15,0"/>

		<!-- Поля -->
		<Grid Grid.Row="1" ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">

			<!-- Колонка 1 -->
			<StackPanel Grid.Column="0" Grid.Row="0" Margin="5">
				<TextBlock Text="Прізвище" Foreground="White" Margin="0,0,0,3"/>
				<TextBox Name="LastNameBox" Background="White" Foreground="Black"/>
			</StackPanel>

			<StackPanel Grid.Column="0" Grid.Row="1" Margin="5">
				<TextBlock Text="Ім'я" Foreground="White" Margin="0,0,0,3"/>
				<TextBox Name="FirstNameBox" Background="White" Foreground="Black"/>
			</StackPanel>

			<StackPanel Grid.Column="0" Grid.Row="2" Margin="5">
				<TextBlock Text="Побатькові" Foreground="White" Margin="0,0,0,3"/>
				<TextBox Name="SurnameBox" Background="White" Foreground="Black"/>
			</StackPanel>

			<StackPanel Grid.Column="0" Grid.Row="3" Margin="5" Orientation="Horizontal">
				<StackPanel Margin="0,0,20,0">
					<TextBlock Text="Стать" Foreground="White" Margin="0,0,0,3"/>
					<ComboBox Name="SexBox" Width="100" Background="White">
						<ComboBoxItem Content="чол"/>
						<ComboBoxItem Content="жін"/>
					</ComboBox>
				</StackPanel>
				<StackPanel>
					<TextBlock Text="Реєстрація" Foreground="White" Margin="0,0,0,3"/>
					<ComboBox Name="RegistrBox" Width="100" Background="White">
						<ComboBoxItem Content="так"/>
						<ComboBoxItem Content="ні"/>
					</ComboBox>
				</StackPanel>
			</StackPanel>

			<StackPanel Grid.Column="0" Grid.Row="4" Margin="5">
				<TextBlock Text="Дата народження" Foreground="White" Margin="0,0,0,3"/>
				<TextBox Name="DateOfBirthBox" Background="White" Foreground="Black"/>
			</StackPanel>

			<!-- Колонка 2 -->
			<StackPanel Grid.Column="1" Grid.Row="0" Margin="5">
				<TextBlock Text="Населений пункт" Foreground="White" Margin="0,0,0,3"/>
				<ComboBox Name="VillageBox" Background="#FFCCAA" HorizontalAlignment="Stretch"/>
			</StackPanel>

			<StackPanel Grid.Column="1" Grid.Row="1" Margin="5">
				<TextBlock Text="Вулиця" Foreground="White" Margin="0,0,0,3"/>
				<ComboBox Name="StreetBox" Background="#FFCCAA" HorizontalAlignment="Stretch"/>
			</StackPanel>

			<StackPanel Grid.Column="1" Grid.Row="2" Margin="5">
				<TextBlock Text="Номер будинку" Foreground="White" Margin="0,0,0,3"/>
				<TextBox Name="HouseBox" Background="White" Foreground="Black"/>
			</StackPanel>

			<StackPanel Grid.Column="1" Grid.Row="3" Margin="5">
				<TextBlock Text="Паспорт" Foreground="White" Margin="0,0,0,3"/>
				<TextBox Name="PassportBox" Background="White" Foreground="Black"
						 Height="80" AcceptsReturn="True" TextWrapping="Wrap"/>
			</StackPanel>

			<StackPanel Grid.Column="1" Grid.Row="4" Margin="5">
				<TextBlock Text="Ідентиф. код" Foreground="White" Margin="0,0,0,3"/>
				<TextBox Name="IdKodBox" Background="White" Foreground="Black"/>
			</StackPanel>

			<!-- Колонка 3 -->
			<StackPanel Grid.Column="2" Grid.Row="0" Margin="5">
				<TextBlock Text="Номер телефону" Foreground="White" Margin="0,0,0,3"/>
				<TextBox Name="PhoneBox" Background="White" Foreground="Black"/>
			</StackPanel>

			<StackPanel Grid.Column="2" Grid.Row="1" Margin="5">
				<TextBlock Text="Статус" Foreground="White" Margin="0,0,0,3"/>
				<ComboBox Name="StatusBox" Background="White" HorizontalAlignment="Stretch">
					<ComboBoxItem Content="помер"/>
					<ComboBoxItem Content="ЗСУ"/>
					<ComboBoxItem Content="ВПО"/>
					<ComboBoxItem Content="одинокий"/>
					<ComboBoxItem Content="безвісти"/>
					<ComboBoxItem Content="не проживає"/>
					<ComboBoxItem Content="відстрочка"/>
					<ComboBoxItem Content="багатодітний"/>
					<ComboBoxItem Content="виключено з в/о"/>
					<ComboBoxItem Content="бронь"/>
					<ComboBoxItem Content="вибув"/>
				</ComboBox>
			</StackPanel>

			<StackPanel Grid.Column="2" Grid.Row="2" Margin="5">
				<TextBlock Text="Дата зміни статусу" Foreground="White" Margin="0,0,0,3"/>
				<TextBox Name="MDateBox" Background="White" Foreground="Black"/>
			</StackPanel>

			<StackPanel Grid.Column="2" Grid.Row="3" Margin="5">
				<TextBlock Text="Опис" Foreground="White" Margin="0,0,0,3"/>
				<TextBox Name="DescriptionBox" Background="White" Foreground="Black"
						 Height="80" AcceptsReturn="True" TextWrapping="Wrap"/>
			</StackPanel>

			<StackPanel Grid.Column="2" Grid.Row="4" Margin="5">
				<TextBlock Text="Військовий ID" Foreground="White" Margin="0,0,0,3"/>
				<TextBox Name="MilIDBox" Background="White" Foreground="Black"/>
			</StackPanel>

		</Grid>

		<!-- Кнопки -->
		<StackPanel Grid.Row="2" Orientation="Horizontal"
					HorizontalAlignment="Right" Margin="0,20,0,0">
			<Button Content="Зберегти зміни"
					Background="Yellow" Foreground="Black"
					FontFamily="Comic Sans MS" FontSize="14"
					FontWeight="Bold" Padding="20,10" Margin="10,0"
					Click="OnSaveClick"/>
			<Button Content="Повернутись"
					Background="#4CAF50" Foreground="White"
					FontFamily="Comic Sans MS" FontSize="14"
					FontWeight="Bold" Padding="20,10"
					Click="OnBackClick"/>
			<Button Name="DeleteBtn" Content="Видалити"
					Background="Red" Foreground="White"
					FontFamily="Comic Sans MS" FontSize="14"
					FontWeight="Bold" Padding="20,10"
					Click="OnDeleteClick"/>
			<!-- Кнопка Довідки з меню -->
			<StackPanel Orientation="Vertical">
				<Button Name="DocumentsBtn" Content="Довідки ▼"
						Background="#2196F3" Foreground="White"
						FontFamily="Comic Sans MS" FontSize="14"
						FontWeight="Bold" Padding="20,10" Margin="10,0"
						Click="OnDocumentsMenuOpen"/>
				<Popup Name="DocumentsPopup" PlacementTarget="{Binding #DocumentsBtn}"
					   Placement="Top" IsLightDismissEnabled="True">
					<Border Background="White" BorderBrush="Gray" BorderThickness="1" Padding="5">
						<StackPanel>
							<Button Name="FamilyBtn" Content="Довідка про склад сім'ї" Background="Transparent"
								    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="10,5"/>
							<Button Name="CharacteristicBtn" Content="Характеристика" Background="Transparent"
									HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="10,5"/>
							<Button Name="TestamentBtn" Content="Заповіт" Background="Transparent"
									HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="10,5"/>
							<Button Name="SubsidyBtn" Content="Довідка на субсидію" Background="Transparent"
									HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="10,5"/>
							<Button Name="BenefitsBtn" Content="Довідка на пільги" Background="Transparent"
									HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="10,5"/>
							<Button Name="TestamentRegBtn" Content="Заява на реєстрацію заповіту" Background="Transparent"
									HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="10,5"/>
						</StackPanel>
					</Border>
				</Popup>
			</StackPanel>
		</StackPanel>

	</Grid>
</Window>
